# URLs públicas das 3 fontes (sem barra no fim).
REFS_URL=https://<refs-catalog>.up.railway.app
LATEFEED_URL=https://latenewsfeed-production.up.railway.app
NOTION_URL=https://<notion-clone>.up.railway.app

# Token compartilhado que o dash envia no header x-summary-token para
# LATEFEED e NOTION. Gere um valor forte e cole o MESMO nos 3 lugares
# (aqui + no .env de cada projeto que expõe /api/summary).
SUMMARY_TOKEN=troque-por-um-segredo-forte

# opcional
# CACHE_TTL_MS=60000
# PORT=4200

# Senha de acesso ao dash (gate de login). Vazio = dash aberto (dev).
DASH_PASSWORD=troque-por-uma-senha

# AppFlowy Web self-hosted (iframe da aba APPFLOWY).
APPFLOWY_URL=https://<appflowy-web>
